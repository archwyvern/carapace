{
  "name": "@carapace/resource-inspector",
  "version": "0.0.1",
  "description": "Glue binding the @carapace/resources model to the @carapace/shell Inspector: a FieldInfo->InspectorField adapter + a <ResourceInspector> component. The only package that knows both worlds.",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@carapace/shell": "workspace:*",
    "@carapace/primitives": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "22.15.17",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "jsdom": "25.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "8.3.5",
    "typescript": "5.9.3",
    "vitest": "3.0.0"
  }
}