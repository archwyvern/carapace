            value += (a5 * a5) * (a5 * a5) * _fnlGradCoord3D(seed2,
                                                             i + PRIME_X, j + (yNMask & (i32(u32(PRIME_Y) << 1u))), k + (zNMask & (i32(u32(PRIME_Z) << 1u))), x5, y5, z5);
        }
    }

    if (!skip9) {
