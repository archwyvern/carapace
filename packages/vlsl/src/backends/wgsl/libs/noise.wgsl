        if (a4 > 0.0) {
            var x4: f32 = f32(xNMask | 1) + x1;
            var y4: f32 = y1;
            var z4: f32 = z1;
            value += (a4 * a4) * (a4 * a4) * _fnlGradCoord3D(seed2,
                                                             i + (xNMask & (PRIME_X * 2)), j + PRIME_Y, k + PRIME_Z, x4, y4, z4);
