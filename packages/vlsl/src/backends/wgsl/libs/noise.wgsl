                _fnlCubicLerp(_fnlValCoord4D(seed,x0,y3,z0,w0), _fnlValCoord4D(seed,x1,y3,z0,w0), _fnlValCoord4D(seed,x2,y3,z0,w0), _fnlValCoord4D(seed,x3,y3,z0,w0), xs),
                ys),
