// --- Fractal warp ---

// Progressive: each octave warps the already-warped coordinates.
// Independent: each octave warps from the original position; displacements are summed.

// --- Progressive ---

fn warp_fractal_progressive_simplex_1d(seed: i32, amplitude: f32, frequency: f32, pos: ptr<function, f32>, octaves: i32, lacunarity: f32, gain: f32) {
    var freq = frequency;
    var amp = amplitude;
    for (var i = 0; i < octaves; i++) {
        warp_simplex_1d(seed + i, amp, freq, pos);
        freq *= lacunarity;
        amp *= gain;
    }
}

