// --- Perlin 4D ---

fn noise_perlin_4d(seed: i32, pos: vec4f) -> f32 {
    var x: f32 = pos.x; var y: f32 = pos.y; var z: f32 = pos.z; var w: f32 = pos.w;

    var x0: i32 = _fnlFastFloor(x);
    var y0: i32 = _fnlFastFloor(y);
    var z0: i32 = _fnlFastFloor(z);
    var w0: i32 = _fnlFastFloor(w);

    var xd0: f32 = x - f32(x0); var yd0: f32 = y - f32(y0);
    var zd0: f32 = z - f32(z0); var wd0: f32 = w - f32(w0);
    var xd1: f32 = xd0 - 1.0; var yd1: f32 = yd0 - 1.0;
    var zd1: f32 = zd0 - 1.0; var wd1: f32 = wd0 - 1.0;

    var xs: f32 = _fnlInterpQuintic(xd0);
    var ys: f32 = _fnlInterpQuintic(yd0);
    var zs: f32 = _fnlInterpQuintic(zd0);
    var ws: f32 = _fnlInterpQuintic(wd0);

    x0 *= PRIME_X; y0 *= PRIME_Y; z0 *= PRIME_Z; w0 *= PRIME_W;
    var x1: i32 = x0 + PRIME_X; var y1: i32 = y0 + PRIME_Y;
    var z1: i32 = z0 + PRIME_Z; var w1: i32 = w0 + PRIME_W;

    var xf000: f32 = mix(_fnlGradCoord4D(seed, x0, y0, z0, w0, xd0, yd0, zd0, wd0), _fnlGradCoord4D(seed, x1, y0, z0, w0, xd1, yd0, zd0, wd0), xs);
    var xf100: f32 = mix(_fnlGradCoord4D(seed, x0, y1, z0, w0, xd0, yd1, zd0, wd0), _fnlGradCoord4D(seed, x1, y1, z0, w0, xd1, yd1, zd0, wd0), xs);
    var xf010: f32 = mix(_fnlGradCoord4D(seed, x0, y0, z1, w0, xd0, yd0, zd1, wd0), _fnlGradCoord4D(seed, x1, y0, z1, w0, xd1, yd0, zd1, wd0), xs);
    var xf110: f32 = mix(_fnlGradCoord4D(seed, x0, y1, z1, w0, xd0, yd1, zd1, wd0), _fnlGradCoord4D(seed, x1, y1, z1, w0, xd1, yd1, zd1, wd0), xs);
    var xf001: f32 = mix(_fnlGradCoord4D(seed, x0, y0, z0, w1, xd0, yd0, zd0, wd1), _fnlGradCoord4D(seed, x1, y0, z0, w1, xd1, yd0, zd0, wd1), xs);
    var xf101: f32 = mix(_fnlGradCoord4D(seed, x0, y1, z0, w1, xd0, yd1, zd0, wd1), _fnlGradCoord4D(seed, x1, y1, z0, w1, xd1, yd1, zd0, wd1), xs);
    var xf011: f32 = mix(_fnlGradCoord4D(seed, x0, y0, z1, w1, xd0, yd0, zd1, wd1), _fnlGradCoord4D(seed, x1, y0, z1, w1, xd1, yd0, zd1, wd1), xs);
    var xf111: f32 = mix(_fnlGradCoord4D(seed, x0, y1, z1, w1, xd0, yd1, zd1, wd1), _fnlGradCoord4D(seed, x1, y1, z1, w1, xd1, yd1, zd1, wd1), xs);

    var yf00: f32 = mix(xf000, xf100, ys);
    var yf10: f32 = mix(xf010, xf110, ys);
    var yf01: f32 = mix(xf001, xf101, ys);
    var yf11: f32 = mix(xf011, xf111, ys);

    var zf0: f32 = mix(yf00, yf10, zs);
    var zf1: f32 = mix(yf01, yf11, zs);

    return mix(zf0, zf1, ws) * 0.964921414852142333984375;
}

// --- Simplex 4D ---

fn noise_simplex_4d(seed: i32, pos: vec4f) -> f32 {
    var x: f32 = pos.x; var y: f32 = pos.y; var z: f32 = pos.z; var w: f32 = pos.w;

    // 4D simplex skew/unskew factors
    let F4: f32 = (sqrt(5.0) - 1.0) / 4.0;
    let G4: f32 = (5.0 - sqrt(5.0)) / 20.0;

    // Skew the (x,y,z,w) space to determine which cell we're in
    var s: f32 = (x + y + z + w) * F4;
    var i: i32 = _fnlFastFloor(x + s);
    var j: i32 = _fnlFastFloor(y + s);
    var k: i32 = _fnlFastFloor(z + s);
    var l: i32 = _fnlFastFloor(w + s);

    var t: f32 = f32(i + j + k + l) * G4;
    var x0: f32 = x - (f32(i) - t);
    var y0: f32 = y - (f32(j) - t);
    var z0: f32 = z - (f32(k) - t);
    var w0: f32 = w - (f32(l) - t);

    // Determine the simplex traversal order by ranking the magnitudes of x0, y0, z0, w0
    var rankx: i32 = 0; var ranky: i32 = 0; var rankz: i32 = 0; var rankw: i32 = 0;
    if (x0 > y0) { rankx++; } else { ranky++; }
    if (x0 > z0) { rankx++; } else { rankz++; }
    if (x0 > w0) { rankx++; } else { rankw++; }
    if (y0 > z0) { ranky++; } else { rankz++; }
    if (y0 > w0) { ranky++; } else { rankw++; }
    if (z0 > w0) { rankz++; } else { rankw++; }

    // simplex[c] is a 4D point with a 1 in each dimension where rank >= 4-c
    var i1: i32 = select(0, 1, rankx >= 3); var j1: i32 = select(0, 1, ranky >= 3);
    var k1: i32 = select(0, 1, rankz >= 3); var l1: i32 = select(0, 1, rankw >= 3);
    var i2: i32 = select(0, 1, rankx >= 2); var j2: i32 = select(0, 1, ranky >= 2);
    var k2: i32 = select(0, 1, rankz >= 2); var l2: i32 = select(0, 1, rankw >= 2);
    var i3: i32 = select(0, 1, rankx >= 1); var j3: i32 = select(0, 1, ranky >= 1);
    var k3: i32 = select(0, 1, rankz >= 1); var l3: i32 = select(0, 1, rankw >= 1);

    var x1: f32 = x0 - f32(i1) + G4;
    var y1: f32 = y0 - f32(j1) + G4;
    var z1: f32 = z0 - f32(k1) + G4;
    var w1: f32 = w0 - f32(l1) + G4;
    var x2: f32 = x0 - f32(i2) + 2.0 * G4;
    var y2: f32 = y0 - f32(j2) + 2.0 * G4;
    var z2: f32 = z0 - f32(k2) + 2.0 * G4;
    var w2: f32 = w0 - f32(l2) + 2.0 * G4;
    var x3: f32 = x0 - f32(i3) + 3.0 * G4;
    var y3: f32 = y0 - f32(j3) + 3.0 * G4;
    var z3: f32 = z0 - f32(k3) + 3.0 * G4;
    var w3: f32 = w0 - f32(l3) + 3.0 * G4;
    var x4: f32 = x0 - 1.0 + 4.0 * G4;
    var y4: f32 = y0 - 1.0 + 4.0 * G4;
    var z4: f32 = z0 - 1.0 + 4.0 * G4;
    var w4: f32 = w0 - 1.0 + 4.0 * G4;

    var ip: i32 = i * PRIME_X; var jp: i32 = j * PRIME_Y;
    var kp: i32 = k * PRIME_Z; var lp: i32 = l * PRIME_W;

    var value: f32 = 0.0;

    var a0: f32 = 0.6 - x0 * x0 - y0 * y0 - z0 * z0 - w0 * w0;
    if (a0 > 0.0) {
        value += (a0 * a0) * (a0 * a0) * _fnlGradCoord4D(seed, ip, jp, kp, lp, x0, y0, z0, w0);
    }

    var a1: f32 = 0.6 - x1 * x1 - y1 * y1 - z1 * z1 - w1 * w1;
    if (a1 > 0.0) {
        value += (a1 * a1) * (a1 * a1) * _fnlGradCoord4D(seed,
            ip + i1 * PRIME_X, jp + j1 * PRIME_Y, kp + k1 * PRIME_Z, lp + l1 * PRIME_W,
            x1, y1, z1, w1);
    }

    var a2: f32 = 0.6 - x2 * x2 - y2 * y2 - z2 * z2 - w2 * w2;
    if (a2 > 0.0) {
        value += (a2 * a2) * (a2 * a2) * _fnlGradCoord4D(seed,
            ip + i2 * PRIME_X, jp + j2 * PRIME_Y, kp + k2 * PRIME_Z, lp + l2 * PRIME_W,
            x2, y2, z2, w2);
    }

    var a3: f32 = 0.6 - x3 * x3 - y3 * y3 - z3 * z3 - w3 * w3;
    if (a3 > 0.0) {
        value += (a3 * a3) * (a3 * a3) * _fnlGradCoord4D(seed,
            ip + i3 * PRIME_X, jp + j3 * PRIME_Y, kp + k3 * PRIME_Z, lp + l3 * PRIME_W,
            x3, y3, z3, w3);
    }

    var a4: f32 = 0.6 - x4 * x4 - y4 * y4 - z4 * z4 - w4 * w4;
    if (a4 > 0.0) {
        value += (a4 * a4) * (a4 * a4) * _fnlGradCoord4D(seed,
            ip + PRIME_X, jp + PRIME_Y, kp + PRIME_Z, lp + PRIME_W,
            x4, y4, z4, w4);
    }

    return value * 27.23;
}

// --- Simplex Smooth 4D ---
// NOTE: Full OpenSimplex2S 4D is not implemented. This aliases to noise_simplex_4d.
// The 4D OpenSimplex2S algorithm requires evaluating a much larger set of contributing
// lattice points and is significantly more complex than the 3D variant.
fn noise_simplex_smooth_4d(seed: i32, pos: vec4f) -> f32 {
    return noise_simplex_4d(seed, pos);
}

// --- Value 4D ---

fn noise_value_4d(seed: i32, pos: vec4f) -> f32 {
    var x: f32 = pos.x; var y: f32 = pos.y; var z: f32 = pos.z; var w: f32 = pos.w;

    var x0: i32 = _fnlFastFloor(x); var y0: i32 = _fnlFastFloor(y);
    var z0: i32 = _fnlFastFloor(z); var w0: i32 = _fnlFastFloor(w);

    var xs: f32 = _fnlInterpHermite(x - f32(x0));
    var ys: f32 = _fnlInterpHermite(y - f32(y0));
    var zs: f32 = _fnlInterpHermite(z - f32(z0));
    var ws: f32 = _fnlInterpHermite(w - f32(w0));

    x0 *= PRIME_X; y0 *= PRIME_Y; z0 *= PRIME_Z; w0 *= PRIME_W;
    var x1: i32 = x0 + PRIME_X; var y1: i32 = y0 + PRIME_Y;
    var z1: i32 = z0 + PRIME_Z; var w1: i32 = w0 + PRIME_W;

    var xf000: f32 = mix(_fnlValCoord4D(seed, x0, y0, z0, w0), _fnlValCoord4D(seed, x1, y0, z0, w0), xs);
    var xf100: f32 = mix(_fnlValCoord4D(seed, x0, y1, z0, w0), _fnlValCoord4D(seed, x1, y1, z0, w0), xs);
    var xf010: f32 = mix(_fnlValCoord4D(seed, x0, y0, z1, w0), _fnlValCoord4D(seed, x1, y0, z1, w0), xs);
    var xf110: f32 = mix(_fnlValCoord4D(seed, x0, y1, z1, w0), _fnlValCoord4D(seed, x1, y1, z1, w0), xs);
    var xf001: f32 = mix(_fnlValCoord4D(seed, x0, y0, z0, w1), _fnlValCoord4D(seed, x1, y0, z0, w1), xs);
    var xf101: f32 = mix(_fnlValCoord4D(seed, x0, y1, z0, w1), _fnlValCoord4D(seed, x1, y1, z0, w1), xs);
    var xf011: f32 = mix(_fnlValCoord4D(seed, x0, y0, z1, w1), _fnlValCoord4D(seed, x1, y0, z1, w1), xs);
    var xf111: f32 = mix(_fnlValCoord4D(seed, x0, y1, z1, w1), _fnlValCoord4D(seed, x1, y1, z1, w1), xs);

    var yf00: f32 = mix(xf000, xf100, ys);
    var yf10: f32 = mix(xf010, xf110, ys);
    var yf01: f32 = mix(xf001, xf101, ys);
    var yf11: f32 = mix(xf011, xf111, ys);

    var zf0: f32 = mix(yf00, yf10, zs);
    var zf1: f32 = mix(yf01, yf11, zs);

    return mix(zf0, zf1, ws);
}

// --- Value Cubic 4D ---
// NOTE: This evaluates 4^4 = 256 sample points. It is expensive.

fn noise_value_cubic_4d(seed: i32, pos: vec4f) -> f32 {
    var x: f32 = pos.x; var y: f32 = pos.y; var z: f32 = pos.z; var w: f32 = pos.w;

    var x1: i32 = _fnlFastFloor(x);
    var y1: i32 = _fnlFastFloor(y);
    var z1: i32 = _fnlFastFloor(z);
    var w1: i32 = _fnlFastFloor(w);

    var xs: f32 = x - f32(x1);
    var ys: f32 = y - f32(y1);
    var zs: f32 = z - f32(z1);
    var ws: f32 = w - f32(w1);

    x1 *= PRIME_X; y1 *= PRIME_Y; z1 *= PRIME_Z; w1 *= PRIME_W;

    var x0: i32 = x1 - PRIME_X; var y0: i32 = y1 - PRIME_Y;
    var z0: i32 = z1 - PRIME_Z; var w0: i32 = w1 - PRIME_W;
    var x2: i32 = x1 + PRIME_X; var y2: i32 = y1 + PRIME_Y;
    var z2: i32 = z1 + PRIME_Z; var w2: i32 = w1 + PRIME_W;
    var x3: i32 = x1 + PRIME_X * 2; var y3: i32 = y1 + PRIME_Y * 2;
    var z3: i32 = z1 + PRIME_Z * 2; var w3: i32 = w1 + PRIME_W * 2;

