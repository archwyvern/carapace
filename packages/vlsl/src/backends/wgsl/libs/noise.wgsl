// ============================================================================
// Utilities
// ============================================================================

fn _fnlFastFloor(f: f32) -> i32 { return i32(floor(f)); }

fn _fnlFastRound(f: f32) -> i32 { return i32(round(f)); }

fn _fnlInterpHermite(t: f32) -> f32 { return t * t * (3.0 - 2.0 * t); }

fn _fnlInterpQuintic(t: f32) -> f32 { return t * t * t * (t * (t * 6.0 - 15.0) + 10.0); }

fn _fnlCubicLerp(a: f32, b: f32, c: f32, d: f32, t: f32) -> f32 {
    var p: f32 = (d - c) - (a - b);
    return t * t * t * p + t * t * ((a - b) - p) + t * (c - a) + b;
}

fn _fnlPingPong(t_in: f32) -> f32 {
    var t: f32 = t_in - f32(i32(t_in * 0.5)) * 2.0;
    return select(2.0 - t, t, t < 1.0);
}

// ============================================================================
// Hashing
// ============================================================================

const PRIME_X: i32 = 501125321;
const PRIME_Y: i32 = 1136930381;
const PRIME_Z: i32 = 1720413743;
const PRIME_W: i32 = 1066049857;

fn _fnlHash1D(seed: i32, xPrimed: i32) -> i32 {
    var hash: i32 = seed ^ xPrimed;
    hash *= 0x27d4eb2d;
    return hash;
}

fn _fnlValCoord1D(seed: i32, xPrimed: i32) -> f32 {
    var hash: i32 = _fnlHash1D(seed, xPrimed);
    hash *= hash;
    hash ^= hash << 19;
    return f32(hash) * (1.0 / 2147483648.0);
}

fn _fnlGradCoord1D(seed: i32, xPrimed: i32, xd: f32) -> f32 {
    var hash: i32 = _fnlHash1D(seed, xPrimed);
    hash ^= hash >> 15;
    hash &= 1;
    return select(-xd, xd, hash == 0);
}

fn _fnlHash2D(seed: i32, xPrimed: i32, yPrimed: i32) -> i32 {
    var hash: i32 = seed ^ xPrimed ^ yPrimed;

    hash *= 0x27d4eb2d;
    return hash;
}

fn _fnlHash3D(seed: i32, xPrimed: i32, yPrimed: i32, zPrimed: i32) -> i32 {
    var hash: i32 = seed ^ xPrimed ^ yPrimed ^ zPrimed;

    hash *= 0x27d4eb2d;
    return hash;
}

fn _fnlValCoord2D(seed: i32, xPrimed: i32, yPrimed: i32) -> f32 {
    var hash: i32 = _fnlHash2D(seed, xPrimed, yPrimed);
    hash *= hash;
    hash ^= hash << 19;
    return f32(hash) * (1.0 / 2147483648.0);
}

fn _fnlValCoord3D(seed: i32, xPrimed: i32, yPrimed: i32, zPrimed: i32) -> f32 {
    var hash: i32 = _fnlHash3D(seed, xPrimed, yPrimed, zPrimed);
    hash *= hash;
    hash ^= hash << 19;
    return f32(hash) * (1.0 / 2147483648.0);
}

fn _fnlGradCoord2D(seed: i32, xPrimed: i32, yPrimed: i32, xd: f32, yd: f32) -> f32 {
    var hash: i32 = _fnlHash2D(seed, xPrimed, yPrimed);
    hash ^= hash >> 15;
    hash &= 127 << 1;
    return xd * GRADIENTS_2D[hash] + yd * GRADIENTS_2D[hash | 1];
}

fn _fnlGradCoord3D(seed: i32, xPrimed: i32, yPrimed: i32, zPrimed: i32, xd: f32, yd: f32, zd: f32) -> f32 {
    var hash: i32 = _fnlHash3D(seed, xPrimed, yPrimed, zPrimed);
    hash ^= hash >> 15;
    hash &= 63 << 2;
    return xd * GRADIENTS_3D[hash] + yd * GRADIENTS_3D[hash | 1] + zd * GRADIENTS_3D[hash | 2];
}

fn _fnlGradCoordOut2D(seed: i32, xPrimed: i32, yPrimed: i32, xo: ptr<function, f32>, yo: ptr<function, f32>) {
    var hash: i32 = _fnlHash2D(seed, xPrimed, yPrimed) & (255 << 1);

    *xo = RAND_VECS_2D[hash];
    *yo = RAND_VECS_2D[hash | 1];
}

fn _fnlGradCoordOut3D(seed: i32, xPrimed: i32, yPrimed: i32, zPrimed: i32, xo: ptr<function, f32>, yo: ptr<function, f32>, zo: ptr<function, f32>) {
    var hash: i32 = _fnlHash3D(seed, xPrimed, yPrimed, zPrimed) & (255 << 2);

    *xo = RAND_VECS_3D[hash];
    *yo = RAND_VECS_3D[hash | 1];
    *zo = RAND_VECS_3D[hash | 2];
}

fn _fnlGradCoordDual2D(seed: i32, xPrimed: i32, yPrimed: i32, xd: f32, yd: f32, xo: ptr<function, f32>, yo: ptr<function, f32>) {
    var hash: i32 = _fnlHash2D(seed, xPrimed, yPrimed);
    var index1: i32 = hash & (127 << 1);
    var index2: i32 = (hash >> 7) & (255 << 1);

    var xg: f32 = GRADIENTS_2D[index1];
    var yg: f32 = GRADIENTS_2D[index1 | 1];
    var value: f32 = xd * xg + yd * yg;

    var xgo: f32 = RAND_VECS_2D[index2];
    var ygo: f32 = RAND_VECS_2D[index2 | 1];

    *xo = value * xgo;
    *yo = value * ygo;
}

fn _fnlGradCoordDual3D(seed: i32, xPrimed: i32, yPrimed: i32, zPrimed: i32, xd: f32, yd: f32, zd: f32, xo: ptr<function, f32>, yo: ptr<function, f32>, zo: ptr<function, f32>) {
    var hash: i32 = _fnlHash3D(seed, xPrimed, yPrimed, zPrimed);
    var index1: i32 = hash & (63 << 2);
    var index2: i32 = (hash >> 6) & (255 << 2);

    var xg: f32 = GRADIENTS_3D[index1];
    var yg: f32 = GRADIENTS_3D[index1 | 1];
    var zg: f32 = GRADIENTS_3D[index1 | 2];
    var value: f32 = xd * xg + yd * yg + zd * zg;

    var xgo: f32 = RAND_VECS_3D[index2];
    var ygo: f32 = RAND_VECS_3D[index2 | 1];
    var zgo: f32 = RAND_VECS_3D[index2 | 2];

    *xo = value * xgo;
    *yo = value * ygo;
    *zo = value * zgo;
}

fn _fnlHash4D(seed: i32, xPrimed: i32, yPrimed: i32, zPrimed: i32, wPrimed: i32) -> i32 {
    var hash: i32 = seed ^ xPrimed ^ yPrimed ^ zPrimed ^ wPrimed;
    hash *= 0x27d4eb2d;
    return hash;
}

fn _fnlValCoord4D(seed: i32, xPrimed: i32, yPrimed: i32, zPrimed: i32, wPrimed: i32) -> f32 {
    var hash: i32 = _fnlHash4D(seed, xPrimed, yPrimed, zPrimed, wPrimed);
    hash *= hash;
    hash ^= hash << 19;
    return f32(hash) * (1.0 / 2147483648.0);
}

fn _fnlGradCoord4D(seed: i32, xPrimed: i32, yPrimed: i32, zPrimed: i32, wPrimed: i32, xd: f32, yd: f32, zd: f32, wd: f32) -> f32 {
    var hash: i32 = _fnlHash4D(seed, xPrimed, yPrimed, zPrimed, wPrimed);
    hash ^= hash >> 15;
    hash &= 31;
    // 32 gradient directions: permutations of (+/-1, +/-1, +/-1, 0)
    // Each gradient has one zero component and three +/-1 components
    var u: f32 = select(yd, xd, hash < 24);
    var v: f32 = select(zd, yd, hash < 16);
    var w: f32 = select(wd, zd, hash < 8);
    return select(u, -u, (hash & 1) != 0) + select(v, -v, (hash & 2) != 0) + select(w, -w, (hash & 4) != 0);
}

// ============================================================================
// 3D Coordinate Transforms
// ============================================================================

// Apply the default simplex R3 rotation (used for simplex/simplex_smooth when no explicit rotation is given)
fn _noise_transform_simplex_3d(x: ptr<function, f32>, y: ptr<function, f32>, z: ptr<function, f32>) {
    let R3: f32 = f32(2.0 / 3.0);
    var r: f32 = (*x + *y + *z) * R3;
    *x = r - *x;
    *y = r - *y;
    *z = r - *z;
}

// Apply a rotation transform for 3D noise. The behavior depends on the noise type:
// - For simplex/simplex_smooth types (is_simplex=true):
//   NOISE_ROTATION_NONE applies the default R3 rotation
// - For grid-based types (is_simplex=false):
//   NOISE_ROTATION_NONE does nothing
fn _noise_transform_3d(x: ptr<function, f32>, y: ptr<function, f32>, z: ptr<function, f32>, rotation: i32, is_simplex: bool) {
    switch (rotation) {
        case 1: {
            var xy: f32 = *x + *y;
            var s2: f32 = xy * -f32(0.211324865405187);
            *z *= f32(0.577350269189626);
            *x += s2 - *z;
            *y = *y + s2 - *z;
            *z += xy * f32(0.577350269189626);
        }
        case 2: {
            var xz: f32 = *x + *z;
            var s2: f32 = xz * -f32(0.211324865405187);
            *y *= f32(0.577350269189626);
            *x += s2 - *y;
            *z += s2 - *y;
            *y += xz * f32(0.577350269189626);
        }
        default: {
            if (is_simplex) {
                _noise_transform_simplex_3d(x, y, z);
            }
        }
    }
}

// ============================================================================
// Simplex (OpenSimplex2) Noise
// ============================================================================

fn noise_simplex_2d(seed: i32, pos: vec2f) -> f32 {
    // Apply 2D simplex skew transform
    let SQRT3: f32 = f32(1.7320508075688772935274463415059);
    let F2: f32 = 0.5 * (SQRT3 - 1.0);
    var t_skew: f32 = (pos.x + pos.y) * F2;
    var x: f32 = pos.x + t_skew;
    var y: f32 = pos.y + t_skew;

    // 2D OpenSimplex2 case uses the same algorithm as ordinary Simplex.

    let G2: f32 = (3.0 - SQRT3) / 6.0;

    var i: i32 = _fnlFastFloor(x);
    var j: i32 = _fnlFastFloor(y);
    var xi: f32 = x - f32(i);
    var yi: f32 = y - f32(j);

    var t: f32 = (xi + yi) * G2;
    var x0: f32 = xi - t;
    var y0: f32 = yi - t;

    i *= PRIME_X;
    j *= PRIME_Y;

    var n0: f32 = 0.0;

    var n1: f32 = 0.0;

    var n2: f32 = 0.0;

    var a: f32 = 0.5 - x0 * x0 - y0 * y0;
    if (a <= 0.0) {
        n0 = 0.0;
    } else {
        n0 = (a * a) * (a * a) * _fnlGradCoord2D(seed, i, j, x0, y0);
    }

    var c: f32 = (2.0 * (1.0 - 2.0 * G2) * (1.0 / G2 - 2.0)) * t + ((-2.0 * (1.0 - 2.0 * G2) * (1.0 - 2.0 * G2)) + a);
    if (c <= 0.0) {
        n2 = 0.0;
    } else {
        var x2: f32 = x0 + (2.0 * G2 - 1.0);
        var y2: f32 = y0 + (2.0 * G2 - 1.0);
        n2 = (c * c) * (c * c) * _fnlGradCoord2D(seed, i + PRIME_X, j + PRIME_Y, x2, y2);
    }

    if (y0 > x0) {
        var x1: f32 = x0 + G2;
        var y1: f32 = y0 + G2 - 1.0;
        var b: f32 = 0.5 - x1 * x1 - y1 * y1;
        if (b <= 0.0) {
            n1 = 0.0;
        } else {
            n1 = (b * b) * (b * b) * _fnlGradCoord2D(seed, i, j + PRIME_Y, x1, y1);
        }
    } else {
        var x1: f32 = x0 + (G2 - 1.0);
        var y1: f32 = y0 + G2;
        var b: f32 = 0.5 - x1 * x1 - y1 * y1;
        if (b <= 0.0) {
            n1 = 0.0;
        } else {
            n1 = (b * b) * (b * b) * _fnlGradCoord2D(seed, i + PRIME_X, j, x1, y1);
        }
    }

    return (n0 + n1 + n2) * 99.83685446303647;
}

fn noise_simplex_3d(seed_in: i32, pos: vec3f) -> f32 {
    var seed: i32 = seed_in;
    // Apply default simplex R3 rotation
    var x: f32 = pos.x;
    var y: f32 = pos.y;
    var z: f32 = pos.z;
    _noise_transform_simplex_3d(&x, &y, &z);

    // 3D OpenSimplex2 case uses two offset rotated cube grids.

    var i: i32 = _fnlFastRound(x);
    var j: i32 = _fnlFastRound(y);
    var k: i32 = _fnlFastRound(z);
    var x0: f32 = x - f32(i);
    var y0: f32 = y - f32(j);
    var z0: f32 = z - f32(k);

    var xNSign: i32 = i32(-1.0 - x0) | 1;
    var yNSign: i32 = i32(-1.0 - y0) | 1;
    var zNSign: i32 = i32(-1.0 - z0) | 1;

    var ax0: f32 = f32(xNSign) * -x0;
    var ay0: f32 = f32(yNSign) * -y0;
    var az0: f32 = f32(zNSign) * -z0;

    i *= PRIME_X;
    j *= PRIME_Y;
    k *= PRIME_Z;

    var value: f32 = 0.0;
    var a: f32 = (0.6 - x0 * x0) - (y0 * y0 + z0 * z0);

    for (var l = 0; ; l++) {
        if (a > 0.0) {
            value += (a * a) * (a * a) * _fnlGradCoord3D(seed, i, j, k, x0, y0, z0);
        }

        var b: f32 = a + 1.0;
        var i1: i32 = i;
        var j1: i32 = j;
        var k1: i32 = k;
        var x1: f32 = x0;
        var y1: f32 = y0;
        var z1: f32 = z0;
        if (ax0 >= ay0 && ax0 >= az0) {
            x1 += f32(xNSign);
            b -= f32(xNSign) * 2.0 * x1;
            i1 -= xNSign * PRIME_X;
        } else if (ay0 > ax0 && ay0 >= az0) {
            y1 += f32(yNSign);
            b -= f32(yNSign) * 2.0 * y1;
            j1 -= yNSign * PRIME_Y;
        } else {
            z1 += f32(zNSign);
            b -= f32(zNSign) * 2.0 * z1;
            k1 -= zNSign * PRIME_Z;
        }

        if (b > 0.0) {
            value += (b * b) * (b * b) * _fnlGradCoord3D(seed, i1, j1, k1, x1, y1, z1);
        }

        if (l == 1) { break; }

        ax0 = 0.5 - ax0;
        ay0 = 0.5 - ay0;
        az0 = 0.5 - az0;

        x0 = f32(xNSign) * ax0;
        y0 = f32(yNSign) * ay0;
        z0 = f32(zNSign) * az0;

        a += (0.75 - ax0) - (ay0 + az0);

        i += (xNSign >> 1) & PRIME_X;
        j += (yNSign >> 1) & PRIME_Y;
        k += (zNSign >> 1) & PRIME_Z;

        xNSign = -xNSign;
        yNSign = -yNSign;
        zNSign = -zNSign;

        seed = ~seed;
    }

    return value * 32.69428253173828125;
}

fn noise_simplex_3d_rot(seed_in: i32, pos: vec3f, rotation: i32) -> f32 {  // was: noise_simplex_3d
    var seed: i32 = seed_in;
    var x: f32 = pos.x;
    var y: f32 = pos.y;
    var z: f32 = pos.z;
    _noise_transform_3d(&x, &y, &z, rotation, true);
    // After transform, call the inner kernel directly (skip the default transform in the base version)
    // We duplicate the kernel here to avoid double-transform

    var i: i32 = _fnlFastRound(x);
    var j: i32 = _fnlFastRound(y);
    var k: i32 = _fnlFastRound(z);
    var x0: f32 = x - f32(i);
    var y0: f32 = y - f32(j);
    var z0: f32 = z - f32(k);

    var xNSign: i32 = i32(-1.0 - x0) | 1;
    var yNSign: i32 = i32(-1.0 - y0) | 1;
    var zNSign: i32 = i32(-1.0 - z0) | 1;

    var ax0: f32 = f32(xNSign) * -x0;
    var ay0: f32 = f32(yNSign) * -y0;
    var az0: f32 = f32(zNSign) * -z0;

    i *= PRIME_X;
    j *= PRIME_Y;
    k *= PRIME_Z;

    var value: f32 = 0.0;
    var a: f32 = (0.6 - x0 * x0) - (y0 * y0 + z0 * z0);

    for (var l = 0; ; l++) {
        if (a > 0.0) {
            value += (a * a) * (a * a) * _fnlGradCoord3D(seed, i, j, k, x0, y0, z0);
        }

        var b: f32 = a + 1.0;
        var i1: i32 = i;
        var j1: i32 = j;
        var k1: i32 = k;
        var x1: f32 = x0;
        var y1: f32 = y0;
        var z1: f32 = z0;
        if (ax0 >= ay0 && ax0 >= az0) {
            x1 += f32(xNSign);
            b -= f32(xNSign) * 2.0 * x1;
            i1 -= xNSign * PRIME_X;
        } else if (ay0 > ax0 && ay0 >= az0) {
            y1 += f32(yNSign);
            b -= f32(yNSign) * 2.0 * y1;
            j1 -= yNSign * PRIME_Y;
        } else {
            z1 += f32(zNSign);
            b -= f32(zNSign) * 2.0 * z1;
            k1 -= zNSign * PRIME_Z;
        }

        if (b > 0.0) {
            value += (b * b) * (b * b) * _fnlGradCoord3D(seed, i1, j1, k1, x1, y1, z1);
        }

        if (l == 1) { break; }

        ax0 = 0.5 - ax0;
        ay0 = 0.5 - ay0;
        az0 = 0.5 - az0;

        x0 = f32(xNSign) * ax0;
        y0 = f32(yNSign) * ay0;
        z0 = f32(zNSign) * az0;

        a += (0.75 - ax0) - (ay0 + az0);

        i += (xNSign >> 1) & PRIME_X;
        j += (yNSign >> 1) & PRIME_Y;
        k += (zNSign >> 1) & PRIME_Z;

        xNSign = -xNSign;
        yNSign = -yNSign;
        zNSign = -zNSign;

        seed = ~seed;
    }

    return value * 32.69428253173828125;
}

