// --- Independent ---

fn warp_fractal_independent_simplex_1d(seed: i32, amplitude: f32, frequency: f32, pos: ptr<function, f32>, octaves: i32, lacunarity: f32, gain: f32) {
    var freq = frequency;
    var amp = amplitude;
    var original: f32 = *pos;
    for (var i = 0; i < octaves; i++) {
        var temp: f32 = original;
        warp_simplex_1d(seed + i, amp, freq, &temp);
        *pos += temp - original;
        freq *= lacunarity;
        amp *= gain;
    }

}

