// Domain Warp
// ============================================================================

// --- Internal warp kernels ---

// 2D simplex gradient warp kernel.
// When outGradOnly is true, uses gradient-only output (reduced quality, cheaper).
// When outGradOnly is false, uses full dual gradient output (OpenSimplex2 quality).
fn _warp_simplex_gradient_2d(seed: i32, warpAmp: f32, frequency: f32, x_in: f32, y_in: f32, xr: ptr<function, f32>, yr: ptr<function, f32>, outGradOnly: bool) {
    let SQRT3: f32 = f32(1.7320508075688772935274463415059);
    let G2: f32 = (3.0 - SQRT3) / 6.0;

    var x: f32 = x_in * frequency;
    var y: f32 = y_in * frequency;

    var i: i32 = _fnlFastFloor(x);
    var j: i32 = _fnlFastFloor(y);
    var xi: f32 = x - f32(i);
    var yi: f32 = y - f32(j);

    var t: f32 = (xi + yi) * G2;
    var x0: f32 = xi - t;
    var y0: f32 = yi - t;

    i *= PRIME_X;
    j *= PRIME_Y;

    var vx: f32 = 0.0;

    var vy: f32 = 0.0;

    var a: f32 = 0.5 - x0 * x0 - y0 * y0;
    if (a > 0.0) {
        var aaaa: f32 = (a * a) * (a * a);
        var xo: f32 = 0.0;
        var yo: f32 = 0.0;
        if (outGradOnly) {
            _fnlGradCoordOut2D(seed, i, j, &xo, &yo);
        } else {
            _fnlGradCoordDual2D(seed, i, j, x0, y0, &xo, &yo);
        }
        vx += aaaa * xo;
        vy += aaaa * yo;
    }

    var c: f32 = (2.0 * (1.0 - 2.0 * G2) * (1.0 / G2 - 2.0)) * t + ((-2.0 * (1.0 - 2.0 * G2) * (1.0 - 2.0 * G2)) + a);
    if (c > 0.0) {
        var x2: f32 = x0 + (2.0 * G2 - 1.0);
        var y2: f32 = y0 + (2.0 * G2 - 1.0);
        var cccc: f32 = (c * c) * (c * c);
        var xo: f32 = 0.0;
        var yo: f32 = 0.0;
        if (outGradOnly) {
            _fnlGradCoordOut2D(seed, i + PRIME_X, j + PRIME_Y, &xo, &yo);
        } else {
            _fnlGradCoordDual2D(seed, i + PRIME_X, j + PRIME_Y, x2, y2, &xo, &yo);
        }
        vx += cccc * xo;
        vy += cccc * yo;
    }

    if (y0 > x0) {
        var x1: f32 = x0 + G2;
        var y1: f32 = y0 + (G2 - 1.0);
        var b: f32 = 0.5 - x1 * x1 - y1 * y1;
        if (b > 0.0) {
            var bbbb: f32 = (b * b) * (b * b);
            var xo: f32 = 0.0;
            var yo: f32 = 0.0;
            if (outGradOnly) {
                _fnlGradCoordOut2D(seed, i, j + PRIME_Y, &xo, &yo);
            } else {
                _fnlGradCoordDual2D(seed, i, j + PRIME_Y, x1, y1, &xo, &yo);
            }
            vx += bbbb * xo;
            vy += bbbb * yo;
        }
    } else {
        var x1: f32 = x0 + (G2 - 1.0);
        var y1: f32 = y0 + G2;
        var b: f32 = 0.5 - x1 * x1 - y1 * y1;
        if (b > 0.0) {
            var bbbb: f32 = (b * b) * (b * b);
            var xo: f32 = 0.0;
            var yo: f32 = 0.0;
            if (outGradOnly) {
                _fnlGradCoordOut2D(seed, i + PRIME_X, j, &xo, &yo);
            } else {
                _fnlGradCoordDual2D(seed, i + PRIME_X, j, x1, y1, &xo, &yo);
            }
            vx += bbbb * xo;
            vy += bbbb * yo;
        }
    }

    *xr += vx * warpAmp;
    *yr += vy * warpAmp;
}

// 3D simplex gradient warp kernel (OpenSimplex2).
// When outGradOnly is true, uses gradient-only output (reduced quality, cheaper).
fn _warp_simplex_gradient_3d(seed_in: i32, warpAmp: f32, frequency: f32, x_in: f32, y_in: f32, z_in: f32, xr: ptr<function, f32>, yr: ptr<function, f32>, zr: ptr<function, f32>, outGradOnly: bool) {
    var seed: i32 = seed_in;
    var x: f32 = x_in * frequency;
    var y: f32 = y_in * frequency;
    var z: f32 = z_in * frequency;

    var i: i32 = _fnlFastRound(x);
    var j: i32 = _fnlFastRound(y);
    var k: i32 = _fnlFastRound(z);
    var x0: f32 = x - f32(i);
    var y0: f32 = y - f32(j);
    var z0: f32 = z - f32(k);

    var xNSign: i32 = i32(-x0 - 1.0) | 1;
    var yNSign: i32 = i32(-y0 - 1.0) | 1;
    var zNSign: i32 = i32(-z0 - 1.0) | 1;

    var ax0: f32 = f32(xNSign) * -x0;
    var ay0: f32 = f32(yNSign) * -y0;
    var az0: f32 = f32(zNSign) * -z0;

    i *= PRIME_X;
    j *= PRIME_Y;
    k *= PRIME_Z;

    var vx: f32 = 0.0;

    var vy: f32 = 0.0;

    var vz: f32 = 0.0;

    var a: f32 = (0.6 - x0 * x0) - (y0 * y0 + z0 * z0);
    for (var l = 0; l < 2; l++) {
        if (a > 0.0) {
            var aaaa: f32 = (a * a) * (a * a);
            var xo: f32 = 0.0;
            var yo: f32 = 0.0;
            var zo: f32 = 0.0;
            if (outGradOnly) {
                _fnlGradCoordOut3D(seed, i, j, k, &xo, &yo, &zo);
            } else {
                _fnlGradCoordDual3D(seed, i, j, k, x0, y0, z0, &xo, &yo, &zo);
            }
            vx += aaaa * xo;
            vy += aaaa * yo;
            vz += aaaa * zo;
        }

        var b: f32 = a + 1.0;
        var i1: i32 = i;
        var j1: i32 = j;
        var k1: i32 = k;
        var x1: f32 = x0;
        var y1: f32 = y0;
        var z1: f32 = z0;
        if (ax0 >= ay0 && ax0 >= az0) {
            x1 += f32(xNSign);
            b -= f32(xNSign) * 2.0 * x1;
            i1 -= xNSign * PRIME_X;
        } else if (ay0 > ax0 && ay0 >= az0) {
            y1 += f32(yNSign);
            b -= f32(yNSign) * 2.0 * y1;
            j1 -= yNSign * PRIME_Y;
        } else {
            z1 += f32(zNSign);
            b -= f32(zNSign) * 2.0 * z1;
            k1 -= zNSign * PRIME_Z;
        }

        if (b > 0.0) {
            var bbbb: f32 = (b * b) * (b * b);
            var xo: f32 = 0.0;
            var yo: f32 = 0.0;
            var zo: f32 = 0.0;
            if (outGradOnly) {
                _fnlGradCoordOut3D(seed, i1, j1, k1, &xo, &yo, &zo);
            } else {
                _fnlGradCoordDual3D(seed, i1, j1, k1, x1, y1, z1, &xo, &yo, &zo);
            }
            vx += bbbb * xo;
            vy += bbbb * yo;
            vz += bbbb * zo;
        }

        if (l == 1) {
            break;
        }

        ax0 = 0.5 - ax0;
        ay0 = 0.5 - ay0;
        az0 = 0.5 - az0;

        x0 = f32(xNSign) * ax0;
        y0 = f32(yNSign) * ay0;
        z0 = f32(zNSign) * az0;

        a += (0.75 - ax0) - (ay0 + az0);

        i += (xNSign >> 1) & PRIME_X;
        j += (yNSign >> 1) & PRIME_Y;
        k += (zNSign >> 1) & PRIME_Z;

        xNSign = -xNSign;
        yNSign = -yNSign;
        zNSign = -zNSign;

        seed += 1293373;
    }

    *xr += vx * warpAmp;
    *yr += vy * warpAmp;
    *zr += vz * warpAmp;
}

// 2D basic grid warp kernel (Hermite-interpolated random vectors).
fn _warp_basic_grid_2d(seed: i32, warpAmp: f32, frequency: f32, x: f32, y: f32, xp: ptr<function, f32>, yp: ptr<function, f32>) {
    var xf: f32 = x * frequency;
    var yf: f32 = y * frequency;

    var x0: i32 = _fnlFastFloor(xf);
    var y0: i32 = _fnlFastFloor(yf);

    var xs: f32 = _fnlInterpHermite(xf - f32(x0));
    var ys: f32 = _fnlInterpHermite(yf - f32(y0));

    x0 *= PRIME_X;
    y0 *= PRIME_Y;
    var x1: i32 = x0 + PRIME_X;
    var y1: i32 = y0 + PRIME_Y;

    var idx0: i32 = _fnlHash2D(seed, x0, y0) & (255 << 1);
    var idx1: i32 = _fnlHash2D(seed, x1, y0) & (255 << 1);

    var lx0x: f32 = mix(RAND_VECS_2D[idx0], RAND_VECS_2D[idx1], xs);
    var ly0x: f32 = mix(RAND_VECS_2D[idx0 | 1], RAND_VECS_2D[idx1 | 1], xs);

    idx0 = _fnlHash2D(seed, x0, y1) & (255 << 1);
    idx1 = _fnlHash2D(seed, x1, y1) & (255 << 1);

    var lx1x: f32 = mix(RAND_VECS_2D[idx0], RAND_VECS_2D[idx1], xs);
    var ly1x: f32 = mix(RAND_VECS_2D[idx0 | 1], RAND_VECS_2D[idx1 | 1], xs);

    *xp += mix(lx0x, lx1x, ys) * warpAmp;
    *yp += mix(ly0x, ly1x, ys) * warpAmp;
}

// 3D basic grid warp kernel (Hermite-interpolated random vectors).
fn _warp_basic_grid_3d(seed: i32, warpAmp: f32, frequency: f32, x: f32, y: f32, z: f32, xp: ptr<function, f32>, yp: ptr<function, f32>, zp: ptr<function, f32>) {
    var xf: f32 = x * frequency;
    var yf: f32 = y * frequency;
    var zf: f32 = z * frequency;

    var x0: i32 = _fnlFastFloor(xf);
    var y0: i32 = _fnlFastFloor(yf);
    var z0: i32 = _fnlFastFloor(zf);

    var xs: f32 = _fnlInterpHermite(xf - f32(x0));
    var ys: f32 = _fnlInterpHermite(yf - f32(y0));
    var zs: f32 = _fnlInterpHermite(zf - f32(z0));

    x0 *= PRIME_X;
    y0 *= PRIME_Y;
    z0 *= PRIME_Z;
    var x1: i32 = x0 + PRIME_X;
    var y1: i32 = y0 + PRIME_Y;
    var z1: i32 = z0 + PRIME_Z;

    var idx0: i32 = _fnlHash3D(seed, x0, y0, z0) & (255 << 2);
    var idx1: i32 = _fnlHash3D(seed, x1, y0, z0) & (255 << 2);

    var lx0x: f32 = mix(RAND_VECS_3D[idx0], RAND_VECS_3D[idx1], xs);
    var ly0x: f32 = mix(RAND_VECS_3D[idx0 | 1], RAND_VECS_3D[idx1 | 1], xs);
    var lz0x: f32 = mix(RAND_VECS_3D[idx0 | 2], RAND_VECS_3D[idx1 | 2], xs);

    idx0 = _fnlHash3D(seed, x0, y1, z0) & (255 << 2);
    idx1 = _fnlHash3D(seed, x1, y1, z0) & (255 << 2);

    var lx1x: f32 = mix(RAND_VECS_3D[idx0], RAND_VECS_3D[idx1], xs);
    var ly1x: f32 = mix(RAND_VECS_3D[idx0 | 1], RAND_VECS_3D[idx1 | 1], xs);
    var lz1x: f32 = mix(RAND_VECS_3D[idx0 | 2], RAND_VECS_3D[idx1 | 2], xs);

    var lx0y: f32 = mix(lx0x, lx1x, ys);
    var ly0y: f32 = mix(ly0x, ly1x, ys);
    var lz0y: f32 = mix(lz0x, lz1x, ys);

    idx0 = _fnlHash3D(seed, x0, y0, z1) & (255 << 2);
    idx1 = _fnlHash3D(seed, x1, y0, z1) & (255 << 2);

    lx0x = mix(RAND_VECS_3D[idx0], RAND_VECS_3D[idx1], xs);
    ly0x = mix(RAND_VECS_3D[idx0 | 1], RAND_VECS_3D[idx1 | 1], xs);
    lz0x = mix(RAND_VECS_3D[idx0 | 2], RAND_VECS_3D[idx1 | 2], xs);

    idx0 = _fnlHash3D(seed, x0, y1, z1) & (255 << 2);
    idx1 = _fnlHash3D(seed, x1, y1, z1) & (255 << 2);

    lx1x = mix(RAND_VECS_3D[idx0], RAND_VECS_3D[idx1], xs);
    ly1x = mix(RAND_VECS_3D[idx0 | 1], RAND_VECS_3D[idx1 | 1], xs);
    lz1x = mix(RAND_VECS_3D[idx0 | 2], RAND_VECS_3D[idx1 | 2], xs);

    *xp += mix(lx0y, mix(lx0x, lx1x, ys), zs) * warpAmp;
    *yp += mix(ly0y, mix(ly0x, ly1x, ys), zs) * warpAmp;
    *zp += mix(lz0y, mix(lz0x, lz1x, ys), zs) * warpAmp;
}

// 1D warp kernel (hash-based gradient interpolation).
fn _warp_1d(seed: i32, amplitude: f32, frequency: f32, pos: ptr<function, f32>) {
    var p: f32 = *pos * frequency;
    var x0: i32 = _fnlFastFloor(p);
    var xd: f32 = p - f32(x0);
    var xs: f32 = _fnlInterpQuintic(xd);

    x0 *= PRIME_X;
    var x1: i32 = x0 + PRIME_X;

    var g0: f32 = _fnlGradCoord1D(seed, x0, 1.0);
    var g1: f32 = _fnlGradCoord1D(seed, x1, 1.0);

    *pos += mix(g0, g1, xs) * amplitude;
}

// 4D basic grid warp kernel (Hermite-interpolated random vectors).
// Full 4D simplex gradient warp is prohibitively complex; grid approach used for all 4D warp variants.
fn _warp_basic_grid_4d(seed: i32, warpAmp: f32, frequency: f32, x: f32, y: f32, z: f32, w: f32, xp: ptr<function, f32>, yp: ptr<function, f32>, zp: ptr<function, f32>, wp: ptr<function, f32>) {
    var xf: f32 = x * frequency;
    var yf: f32 = y * frequency;
    var zf: f32 = z * frequency;
    var wf: f32 = w * frequency;

    var x0: i32 = _fnlFastFloor(xf);
    var y0: i32 = _fnlFastFloor(yf);
    var z0: i32 = _fnlFastFloor(zf);
    var w0: i32 = _fnlFastFloor(wf);

    var xs: f32 = _fnlInterpHermite(xf - f32(x0));
    var ys: f32 = _fnlInterpHermite(yf - f32(y0));
    var zs: f32 = _fnlInterpHermite(zf - f32(z0));
    var ws: f32 = _fnlInterpHermite(wf - f32(w0));

    x0 *= PRIME_X;
    y0 *= PRIME_Y;
    z0 *= PRIME_Z;
    w0 *= PRIME_W;
    var x1: i32 = x0 + PRIME_X;
    var y1: i32 = y0 + PRIME_Y;
    var z1: i32 = z0 + PRIME_Z;
    var w1: i32 = w0 + PRIME_W;

    // For each output component, trilinearly interpolate hash-derived random values.
    // We use the hash to index a pseudo-random value per corner, one component at a time.

    // X component
    var h0000: f32 = f32(_fnlHash4D(seed, x0, y0, z0, w0) & 0xFF) / 127.5 - 1.0;
    var h1000: f32 = f32(_fnlHash4D(seed, x1, y0, z0, w0) & 0xFF) / 127.5 - 1.0;
    var h0100: f32 = f32(_fnlHash4D(seed, x0, y1, z0, w0) & 0xFF) / 127.5 - 1.0;
    var h1100: f32 = f32(_fnlHash4D(seed, x1, y1, z0, w0) & 0xFF) / 127.5 - 1.0;
    var h0010: f32 = f32(_fnlHash4D(seed, x0, y0, z1, w0) & 0xFF) / 127.5 - 1.0;
    var h1010: f32 = f32(_fnlHash4D(seed, x1, y0, z1, w0) & 0xFF) / 127.5 - 1.0;
    var h0110: f32 = f32(_fnlHash4D(seed, x0, y1, z1, w0) & 0xFF) / 127.5 - 1.0;
    var h1110: f32 = f32(_fnlHash4D(seed, x1, y1, z1, w0) & 0xFF) / 127.5 - 1.0;
    var h0001: f32 = f32(_fnlHash4D(seed, x0, y0, z0, w1) & 0xFF) / 127.5 - 1.0;
    var h1001: f32 = f32(_fnlHash4D(seed, x1, y0, z0, w1) & 0xFF) / 127.5 - 1.0;
    var h0101: f32 = f32(_fnlHash4D(seed, x0, y1, z0, w1) & 0xFF) / 127.5 - 1.0;
    var h1101: f32 = f32(_fnlHash4D(seed, x1, y1, z0, w1) & 0xFF) / 127.5 - 1.0;
    var h0011: f32 = f32(_fnlHash4D(seed, x0, y0, z1, w1) & 0xFF) / 127.5 - 1.0;
    var h1011: f32 = f32(_fnlHash4D(seed, x1, y0, z1, w1) & 0xFF) / 127.5 - 1.0;
    var h0111: f32 = f32(_fnlHash4D(seed, x0, y1, z1, w1) & 0xFF) / 127.5 - 1.0;
    var h1111: f32 = f32(_fnlHash4D(seed, x1, y1, z1, w1) & 0xFF) / 127.5 - 1.0;

    *xp += mix(mix(mix(mix(h0000, h1000, xs), mix(h0100, h1100, xs), ys),
                   mix(mix(h0010, h1010, xs), mix(h0110, h1110, xs), ys), zs),
               mix(mix(mix(h0001, h1001, xs), mix(h0101, h1101, xs), ys),
                   mix(mix(h0011, h1011, xs), mix(h0111, h1111, xs), ys), zs), ws) * warpAmp;

    // Y component (offset seed to get independent values)
    var seed2: i32 = seed + 1293373;
    h0000 = f32(_fnlHash4D(seed2, x0, y0, z0, w0) & 0xFF) / 127.5 - 1.0;
    h1000 = f32(_fnlHash4D(seed2, x1, y0, z0, w0) & 0xFF) / 127.5 - 1.0;
    h0100 = f32(_fnlHash4D(seed2, x0, y1, z0, w0) & 0xFF) / 127.5 - 1.0;
    h1100 = f32(_fnlHash4D(seed2, x1, y1, z0, w0) & 0xFF) / 127.5 - 1.0;
    h0010 = f32(_fnlHash4D(seed2, x0, y0, z1, w0) & 0xFF) / 127.5 - 1.0;
    h1010 = f32(_fnlHash4D(seed2, x1, y0, z1, w0) & 0xFF) / 127.5 - 1.0;
    h0110 = f32(_fnlHash4D(seed2, x0, y1, z1, w0) & 0xFF) / 127.5 - 1.0;
    h1110 = f32(_fnlHash4D(seed2, x1, y1, z1, w0) & 0xFF) / 127.5 - 1.0;
    h0001 = f32(_fnlHash4D(seed2, x0, y0, z0, w1) & 0xFF) / 127.5 - 1.0;
    h1001 = f32(_fnlHash4D(seed2, x1, y0, z0, w1) & 0xFF) / 127.5 - 1.0;
    h0101 = f32(_fnlHash4D(seed2, x0, y1, z0, w1) & 0xFF) / 127.5 - 1.0;
    h1101 = f32(_fnlHash4D(seed2, x1, y1, z0, w1) & 0xFF) / 127.5 - 1.0;
    h0011 = f32(_fnlHash4D(seed2, x0, y0, z1, w1) & 0xFF) / 127.5 - 1.0;
    h1011 = f32(_fnlHash4D(seed2, x1, y0, z1, w1) & 0xFF) / 127.5 - 1.0;
    h0111 = f32(_fnlHash4D(seed2, x0, y1, z1, w1) & 0xFF) / 127.5 - 1.0;
    h1111 = f32(_fnlHash4D(seed2, x1, y1, z1, w1) & 0xFF) / 127.5 - 1.0;

    *yp += mix(mix(mix(mix(h0000, h1000, xs), mix(h0100, h1100, xs), ys),
                   mix(mix(h0010, h1010, xs), mix(h0110, h1110, xs), ys), zs),
               mix(mix(mix(h0001, h1001, xs), mix(h0101, h1101, xs), ys),
                   mix(mix(h0011, h1011, xs), mix(h0111, h1111, xs), ys), zs), ws) * warpAmp;

    // Z component
    var seed3: i32 = seed + 2586746;
    h0000 = f32(_fnlHash4D(seed3, x0, y0, z0, w0) & 0xFF) / 127.5 - 1.0;
    h1000 = f32(_fnlHash4D(seed3, x1, y0, z0, w0) & 0xFF) / 127.5 - 1.0;
    h0100 = f32(_fnlHash4D(seed3, x0, y1, z0, w0) & 0xFF) / 127.5 - 1.0;
    h1100 = f32(_fnlHash4D(seed3, x1, y1, z0, w0) & 0xFF) / 127.5 - 1.0;
    h0010 = f32(_fnlHash4D(seed3, x0, y0, z1, w0) & 0xFF) / 127.5 - 1.0;
    h1010 = f32(_fnlHash4D(seed3, x1, y0, z1, w0) & 0xFF) / 127.5 - 1.0;
    h0110 = f32(_fnlHash4D(seed3, x0, y1, z1, w0) & 0xFF) / 127.5 - 1.0;
    h1110 = f32(_fnlHash4D(seed3, x1, y1, z1, w0) & 0xFF) / 127.5 - 1.0;
    h0001 = f32(_fnlHash4D(seed3, x0, y0, z0, w1) & 0xFF) / 127.5 - 1.0;
    h1001 = f32(_fnlHash4D(seed3, x1, y0, z0, w1) & 0xFF) / 127.5 - 1.0;
    h0101 = f32(_fnlHash4D(seed3, x0, y1, z0, w1) & 0xFF) / 127.5 - 1.0;
    h1101 = f32(_fnlHash4D(seed3, x1, y1, z0, w1) & 0xFF) / 127.5 - 1.0;
    h0011 = f32(_fnlHash4D(seed3, x0, y0, z1, w1) & 0xFF) / 127.5 - 1.0;
    h1011 = f32(_fnlHash4D(seed3, x1, y0, z1, w1) & 0xFF) / 127.5 - 1.0;
    h0111 = f32(_fnlHash4D(seed3, x0, y1, z1, w1) & 0xFF) / 127.5 - 1.0;
    h1111 = f32(_fnlHash4D(seed3, x1, y1, z1, w1) & 0xFF) / 127.5 - 1.0;

    *zp += mix(mix(mix(mix(h0000, h1000, xs), mix(h0100, h1100, xs), ys),
                   mix(mix(h0010, h1010, xs), mix(h0110, h1110, xs), ys), zs),
               mix(mix(mix(h0001, h1001, xs), mix(h0101, h1101, xs), ys),
                   mix(mix(h0011, h1011, xs), mix(h0111, h1111, xs), ys), zs), ws) * warpAmp;

    // W component
    var seed4: i32 = seed + 3880119;
    h0000 = f32(_fnlHash4D(seed4, x0, y0, z0, w0) & 0xFF) / 127.5 - 1.0;
    h1000 = f32(_fnlHash4D(seed4, x1, y0, z0, w0) & 0xFF) / 127.5 - 1.0;
    h0100 = f32(_fnlHash4D(seed4, x0, y1, z0, w0) & 0xFF) / 127.5 - 1.0;
    h1100 = f32(_fnlHash4D(seed4, x1, y1, z0, w0) & 0xFF) / 127.5 - 1.0;
    h0010 = f32(_fnlHash4D(seed4, x0, y0, z1, w0) & 0xFF) / 127.5 - 1.0;
    h1010 = f32(_fnlHash4D(seed4, x1, y0, z1, w0) & 0xFF) / 127.5 - 1.0;
    h0110 = f32(_fnlHash4D(seed4, x0, y1, z1, w0) & 0xFF) / 127.5 - 1.0;
    h1110 = f32(_fnlHash4D(seed4, x1, y1, z1, w0) & 0xFF) / 127.5 - 1.0;
    h0001 = f32(_fnlHash4D(seed4, x0, y0, z0, w1) & 0xFF) / 127.5 - 1.0;
    h1001 = f32(_fnlHash4D(seed4, x1, y0, z0, w1) & 0xFF) / 127.5 - 1.0;
    h0101 = f32(_fnlHash4D(seed4, x0, y1, z0, w1) & 0xFF) / 127.5 - 1.0;
    h1101 = f32(_fnlHash4D(seed4, x1, y1, z0, w1) & 0xFF) / 127.5 - 1.0;
    h0011 = f32(_fnlHash4D(seed4, x0, y0, z1, w1) & 0xFF) / 127.5 - 1.0;
    h1011 = f32(_fnlHash4D(seed4, x1, y0, z1, w1) & 0xFF) / 127.5 - 1.0;
    h0111 = f32(_fnlHash4D(seed4, x0, y1, z1, w1) & 0xFF) / 127.5 - 1.0;
    h1111 = f32(_fnlHash4D(seed4, x1, y1, z1, w1) & 0xFF) / 127.5 - 1.0;

    *wp += mix(mix(mix(mix(h0000, h1000, xs), mix(h0100, h1100, xs), ys),
                   mix(mix(h0010, h1010, xs), mix(h0110, h1110, xs), ys), zs),
               mix(mix(mix(h0001, h1001, xs), mix(h0101, h1101, xs), ys),
                   mix(mix(h0011, h1011, xs), mix(h0111, h1111, xs), ys), zs), ws) * warpAmp;
}

// --- Single-shot warp ---

// 1D warp functions (all three algorithms share the same implementation)

fn warp_simplex_1d(seed: i32, amplitude: f32, frequency: f32, pos: ptr<function, f32>) {
    _warp_1d(seed, amplitude, frequency, pos);
}

fn warp_simplex_reduced_1d(seed: i32, amplitude: f32, frequency: f32, pos: ptr<function, f32>) {
    _warp_1d(seed, amplitude, frequency, pos);
}

fn warp_grid_1d(seed: i32, amplitude: f32, frequency: f32, pos: ptr<function, f32>) {
    _warp_1d(seed, amplitude, frequency, pos);
}

// 2D warp functions

fn warp_simplex_2d(seed: i32, amplitude: f32, frequency: f32, pos: ptr<function, vec2f>) {
    // Apply F2 skew (same as noise_simplex_2d)
    let SQRT3: f32 = f32(1.7320508075688772935274463415059);
    let F2: f32 = 0.5 * (SQRT3 - 1.0);
    var t_skew: f32 = ((*pos).x + (*pos).y) * F2;
    var xs: f32 = (*pos).x + t_skew;
    var ys: f32 = (*pos).y + t_skew;

    var rx: f32 = (*pos).x;
    var ry: f32 = (*pos).y;
    _warp_simplex_gradient_2d(seed, amplitude * 38.283687591552734375, frequency, xs, ys, &rx, &ry, false);
    (*pos).x = rx;
    (*pos).y = ry;
}

fn warp_simplex_reduced_2d(seed: i32, amplitude: f32, frequency: f32, pos: ptr<function, vec2f>) {
    let SQRT3: f32 = f32(1.7320508075688772935274463415059);
    let F2: f32 = 0.5 * (SQRT3 - 1.0);
    var t_skew: f32 = ((*pos).x + (*pos).y) * F2;
    var xs: f32 = (*pos).x + t_skew;
    var ys: f32 = (*pos).y + t_skew;

    var rx: f32 = (*pos).x;
    var ry: f32 = (*pos).y;
    _warp_simplex_gradient_2d(seed, amplitude * 16.0, frequency, xs, ys, &rx, &ry, true);
    (*pos).x = rx;
    (*pos).y = ry;
}

fn warp_grid_2d(seed: i32, amplitude: f32, frequency: f32, pos: ptr<function, vec2f>) {
    var rx: f32 = (*pos).x;
    var ry: f32 = (*pos).y;
    _warp_basic_grid_2d(seed, amplitude, frequency, (*pos).x, (*pos).y, &rx, &ry);
    (*pos).x = rx;
    (*pos).y = ry;
}

// 3D warp functions

fn warp_simplex_3d(seed: i32, amplitude: f32, frequency: f32, pos: ptr<function, vec3f>) {
    // Apply R3 rotation (same as simplex noise 3D)
    let R3: f32 = f32(2.0 / 3.0);
    var r: f32 = ((*pos).x + (*pos).y + (*pos).z) * R3;
    var xs: f32 = r - (*pos).x;
    var ys: f32 = r - (*pos).y;
    var zs: f32 = r - (*pos).z;

    var rx: f32 = (*pos).x;
    var ry: f32 = (*pos).y;
    var rz: f32 = (*pos).z;
    _warp_simplex_gradient_3d(seed, amplitude * 32.69428253173828125, frequency, xs, ys, zs, &rx, &ry, &rz, false);
    (*pos).x = rx;
    (*pos).y = ry;
    (*pos).z = rz;
}

