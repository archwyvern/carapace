fn noise_simplex_smooth_2d(seed: i32, pos: vec2f) -> f32 {
    // Apply 2D simplex skew transform
    let SQRT3: f32 = f32(1.7320508075688772935274463415059);
    let F2: f32 = 0.5 * (SQRT3 - 1.0);
    var t_skew: f32 = (pos.x + pos.y) * F2;
    var x: f32 = pos.x + t_skew;
    var y: f32 = pos.y + t_skew;

    // 2D OpenSimplex2S case is a modified 2D simplex noise.

    let G2: f32 = (3.0 - SQRT3) / 6.0;

    var i: i32 = _fnlFastFloor(x);
    var j: i32 = _fnlFastFloor(y);
    var xi: f32 = x - f32(i);
    var yi: f32 = y - f32(j);

    i *= PRIME_X;
    j *= PRIME_Y;
    var i1: i32 = i + PRIME_X;
    var j1: i32 = j + PRIME_Y;

    var t: f32 = (xi + yi) * G2;
    var x0: f32 = xi - t;
    var y0: f32 = yi - t;

    var aMask: i32 = i32((xi + yi + 1.0) * -0.5);
    var bMask: i32 = i32((xi - (f32(aMask) + 2.0)) * 0.5 - yi);
    var cMask: i32 = i32((yi - (f32(aMask) + 2.0)) * 0.5 - xi);

    var a0: f32 = (2.0 / 3.0) - x0 * x0 - y0 * y0;
    var value: f32 = (a0 * a0) * (a0 * a0) * _fnlGradCoord2D(seed, i, j, x0, y0);

    var a1: f32 = (2.0 * (1.0 - 2.0 * G2) * (1.0 / G2 - 2.0)) * t + ((-2.0 * (1.0 - 2.0 * G2) * (1.0 - 2.0 * G2)) + a0);
    var x1: f32 = x0 - (1.0 - 2.0 * G2);
    var y1: f32 = y0 - (1.0 - 2.0 * G2);
    value += (a1 * a1) * (a1 * a1) * _fnlGradCoord2D(seed, i1, j1, x1, y1);

    var di2: i32 = ~(aMask | cMask) | 1;
    var ndj2: i32 = (aMask & bMask) << 1;
    var t2: f32 = f32(di2 - ndj2) * G2;
    var x2: f32 = x0 - f32(di2) + t2;
    var y2: f32 = y0 + f32(ndj2) + t2;
    var a2: f32 = (2.0 / 3.0) - x2 * x2 - y2 * y2;
    if (a2 > 0.0) {
        value += (a2 * a2) * (a2 * a2) * _fnlGradCoord2D(seed, i1 + (di2 & (-i32(u32(PRIME_X) << 1u))), j + (ndj2 & (i32(u32(PRIME_Y) << 1u))), x2, y2);
    }

    var ndi3: i32 = (aMask & cMask) << 1;
    var dj3: i32 = ~(aMask | bMask) | 1;
    var t3: f32 = f32(dj3 - ndi3) * G2;
    var x3: f32 = x0 + f32(ndi3) + t3;
    var y3: f32 = y0 - f32(dj3) + t3;
    var a3: f32 = (2.0 / 3.0) - x3 * x3 - y3 * y3;
    if (a3 > 0.0) {
        value += (a3 * a3) * (a3 * a3) * _fnlGradCoord2D(seed, i + (ndi3 & (i32(u32(PRIME_X) << 1u))), j1 + (dj3 & (-i32(u32(PRIME_Y) << 1u))), x3, y3);
    }

    return value * 18.24196194486065;
}

fn noise_simplex_smooth_3d(seed: i32, pos: vec3f) -> f32 {
    // Apply default simplex R3 rotation
    var x: f32 = pos.x;
    var y: f32 = pos.y;
    var z: f32 = pos.z;
    _noise_transform_simplex_3d(&x, &y, &z);

