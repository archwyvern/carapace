    var xf00: f32 = mix(_fnlValCoord3D(seed, x0, y0, z0), _fnlValCoord3D(seed, x1, y0, z0), xs);
    var xf10: f32 = mix(_fnlValCoord3D(seed, x0, y1, z0), _fnlValCoord3D(seed, x1, y1, z0), xs);
    var xf01: f32 = mix(_fnlValCoord3D(seed, x0, y0, z1), _fnlValCoord3D(seed, x1, y0, z1), xs);
    var xf11: f32 = mix(_fnlValCoord3D(seed, x0, y1, z1), _fnlValCoord3D(seed, x1, y1, z1), xs);

    var yf0: f32 = mix(xf00, xf10, ys);
    var yf1: f32 = mix(xf01, xf11, ys);

    return mix(yf0, yf1, zs);
}

fn noise_value_3d_rot(seed: i32, pos: vec3f, rotation: i32) -> f32 {  // was: noise_value_3d
    var x: f32 = pos.x;
    var y: f32 = pos.y;
    var z: f32 = pos.z;
    _noise_transform_3d(&x, &y, &z, rotation, false);
    return noise_value_3d(seed, vec3f(x, y, z));
}

