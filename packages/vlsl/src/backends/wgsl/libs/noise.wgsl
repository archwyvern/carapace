// --- Cellular 4D ---
// Searches a 3^4 = 81-cell neighborhood. Uses hash-generated jitter positions
// instead of a RAND_VECS_4D table.

fn noise_cellular_4d(seed: i32, pos: vec4f, distance_func: i32, return_type: i32, jitter: f32) -> f32 {
    var x: f32 = pos.x; var y: f32 = pos.y; var z: f32 = pos.z; var w: f32 = pos.w;

    var xr: i32 = _fnlFastRound(x);
    var yr: i32 = _fnlFastRound(y);
    var zr: i32 = _fnlFastRound(z);
    var wr: i32 = _fnlFastRound(w);

    var distance0: f32 = 1e10;
    var distance1: f32 = 1e10;
    var closestHash: i32 = 0;

    var cellularJitter: f32 = 0.39614353 * jitter;

    var xPrimed: i32 = (xr - 1) * PRIME_X;
    var yPrimedBase: i32 = (yr - 1) * PRIME_Y;
    var zPrimedBase: i32 = (zr - 1) * PRIME_Z;
    var wPrimedBase: i32 = (wr - 1) * PRIME_W;

    switch (distance_func) {
    case 2: {
        for (var xi = xr - 1; xi <= xr + 1; xi++) {
            var yPrimed: i32 = yPrimedBase;
            for (var yi = yr - 1; yi <= yr + 1; yi++) {
                var zPrimed: i32 = zPrimedBase;
                for (var zi = zr - 1; zi <= zr + 1; zi++) {
                    var wPrimed: i32 = wPrimedBase;
                    for (var wi = wr - 1; wi <= wr + 1; wi++) {
                        var hash: i32 = _fnlHash4D(seed, xPrimed, yPrimed, zPrimed, wPrimed);

                        var vecX: f32 = f32(xi) - x + (f32(hash & 0xFF) * (1.0 / 255.0) - 0.5) * 2.0 * cellularJitter;
                        var vecY: f32 = f32(yi) - y + (f32((hash >> 8) & 0xFF) * (1.0 / 255.0) - 0.5) * 2.0 * cellularJitter;
                        var vecZ: f32 = f32(zi) - z + (f32((hash >> 16) & 0xFF) * (1.0 / 255.0) - 0.5) * 2.0 * cellularJitter;
                        var vecW: f32 = f32(wi) - w + (f32((hash >> 24) & 0xFF) * (1.0 / 255.0) - 0.5) * 2.0 * cellularJitter;

                        var newDistance: f32 = abs(vecX) + abs(vecY) + abs(vecZ) + abs(vecW);

                        distance1 = max(min(distance1, newDistance), distance0);
                        if (newDistance < distance0) {
                            distance0 = newDistance;
                            closestHash = hash;
                        }
                        wPrimed += PRIME_W;
                    }
                    zPrimed += PRIME_Z;
                }
                yPrimed += PRIME_Y;
            }
            xPrimed += PRIME_X;
        }
    }
    case 3: {
        for (var xi = xr - 1; xi <= xr + 1; xi++) {
            var yPrimed: i32 = yPrimedBase;
            for (var yi = yr - 1; yi <= yr + 1; yi++) {
                var zPrimed: i32 = zPrimedBase;
                for (var zi = zr - 1; zi <= zr + 1; zi++) {
                    var wPrimed: i32 = wPrimedBase;
                    for (var wi = wr - 1; wi <= wr + 1; wi++) {
                        var hash: i32 = _fnlHash4D(seed, xPrimed, yPrimed, zPrimed, wPrimed);

                        var vecX: f32 = f32(xi) - x + (f32(hash & 0xFF) * (1.0 / 255.0) - 0.5) * 2.0 * cellularJitter;
                        var vecY: f32 = f32(yi) - y + (f32((hash >> 8) & 0xFF) * (1.0 / 255.0) - 0.5) * 2.0 * cellularJitter;
                        var vecZ: f32 = f32(zi) - z + (f32((hash >> 16) & 0xFF) * (1.0 / 255.0) - 0.5) * 2.0 * cellularJitter;
                        var vecW: f32 = f32(wi) - w + (f32((hash >> 24) & 0xFF) * (1.0 / 255.0) - 0.5) * 2.0 * cellularJitter;

                        var newDistance: f32 = (abs(vecX) + abs(vecY) + abs(vecZ) + abs(vecW))
                            + (vecX * vecX + vecY * vecY + vecZ * vecZ + vecW * vecW);

                        distance1 = max(min(distance1, newDistance), distance0);
                        if (newDistance < distance0) {
                            distance0 = newDistance;
                            closestHash = hash;
                        }
                        wPrimed += PRIME_W;
                    }
                    zPrimed += PRIME_Z;
                }
                yPrimed += PRIME_Y;
            }
            xPrimed += PRIME_X;
        }
    }
    default {
        for (var xi = xr - 1; xi <= xr + 1; xi++) {
            var yPrimed: i32 = yPrimedBase;
            for (var yi = yr - 1; yi <= yr + 1; yi++) {
                var zPrimed: i32 = zPrimedBase;
                for (var zi = zr - 1; zi <= zr + 1; zi++) {
                    var wPrimed: i32 = wPrimedBase;
                    for (var wi = wr - 1; wi <= wr + 1; wi++) {
                        var hash: i32 = _fnlHash4D(seed, xPrimed, yPrimed, zPrimed, wPrimed);

                        var vecX: f32 = f32(xi) - x + (f32(hash & 0xFF) * (1.0 / 255.0) - 0.5) * 2.0 * cellularJitter;
                        var vecY: f32 = f32(yi) - y + (f32((hash >> 8) & 0xFF) * (1.0 / 255.0) - 0.5) * 2.0 * cellularJitter;
                        var vecZ: f32 = f32(zi) - z + (f32((hash >> 16) & 0xFF) * (1.0 / 255.0) - 0.5) * 2.0 * cellularJitter;
                        var vecW: f32 = f32(wi) - w + (f32((hash >> 24) & 0xFF) * (1.0 / 255.0) - 0.5) * 2.0 * cellularJitter;

                        var newDistance: f32 = vecX * vecX + vecY * vecY + vecZ * vecZ + vecW * vecW;

                        distance1 = max(min(distance1, newDistance), distance0);
                        if (newDistance < distance0) {
                            distance0 = newDistance;
                            closestHash = hash;
                        }
                        wPrimed += PRIME_W;
                    }
                    zPrimed += PRIME_Z;
                }
                yPrimed += PRIME_Y;
            }
            xPrimed += PRIME_X;
        }
    }
    }

    if (distance_func == NOISE_CELLULAR_EUCLIDEAN && return_type >= NOISE_CELLULAR_DISTANCE) {
        distance0 = sqrt(distance0);
        if (return_type >= NOISE_CELLULAR_DISTANCE2) {
            distance1 = sqrt(distance1);
        }
    }

    switch (return_type) {
    case 0 { return f32(closestHash) * (1.0 / 2147483648.0); }
    case 1 { return distance0 - 1.0; }
    case 2 { return distance1 - 1.0; }
    case 3 { return (distance1 + distance0) * 0.5 - 1.0; }
    case 4 { return distance1 - distance0 - 1.0; }
    case 5 { return distance1 * distance0 * 0.5 - 1.0; }
    case 6 { return distance0 / distance1 - 1.0; }
    default { return 0.0; }
    }

}

fn noise_cellular_4d_default(seed: i32, pos: vec4f, distance_func: i32, return_type: i32) -> f32 {  // was: noise_cellular_4d
    return noise_cellular_4d(seed, pos, distance_func, return_type, 1.0);
}

// ============================================================================
// 1D Noise
// ============================================================================

fn noise_perlin_1d(seed: i32, pos: f32) -> f32 {
    var x0: i32 = _fnlFastFloor(pos);
    var xd0: f32 = pos - f32(x0);
    var xd1: f32 = xd0 - 1.0;
    var xs: f32 = _fnlInterpQuintic(xd0);

    x0 *= PRIME_X;
    var x1: i32 = x0 + PRIME_X;

    return mix(_fnlGradCoord1D(seed, x0, xd0), _fnlGradCoord1D(seed, x1, xd1), xs);
}

fn noise_value_1d(seed: i32, pos: f32) -> f32 {
    var x0: i32 = _fnlFastFloor(pos);
    var xs: f32 = _fnlInterpHermite(pos - f32(x0));

    x0 *= PRIME_X;
    var x1: i32 = x0 + PRIME_X;

    return mix(_fnlValCoord1D(seed, x0), _fnlValCoord1D(seed, x1), xs);
}

fn noise_value_cubic_1d(seed: i32, pos: f32) -> f32 {
    var x1: i32 = _fnlFastFloor(pos);
    var xs: f32 = pos - f32(x1);

    x1 *= PRIME_X;
    var x0: i32 = x1 - PRIME_X;
    var x2: i32 = x1 + PRIME_X;
    var x3: i32 = x1 + PRIME_X * 2;

    return _fnlCubicLerp(_fnlValCoord1D(seed, x0), _fnlValCoord1D(seed, x1), _fnlValCoord1D(seed, x2), _fnlValCoord1D(seed, x3), xs) * (1.0 / 1.5);
}

fn noise_simplex_1d(seed: i32, pos: f32) -> f32 { return noise_perlin_1d(seed, pos); }
fn noise_simplex_smooth_1d(seed: i32, pos: f32) -> f32 { return noise_perlin_1d(seed, pos); }

// ============================================================================
// Fractal Noise
// ============================================================================

fn _noise_fractal_bounding(octaves: i32, gain: f32) -> f32 {
    var g: f32 = abs(gain);
    var amp: f32 = g;
    var ampFractal: f32 = 1.0;
    for (var i = 1; i < octaves; i++) {
        ampFractal += amp;
        amp *= g;
    }
    return 1.0 / ampFractal;
}

// --- FBm ---

fn fractal_fbm_simplex_1d(seed: i32, pos: f32, octaves: i32, lacunarity: f32, gain: f32, weighted_strength: f32) -> f32 {
    var p = pos;
    var sum: f32 = 0.0;
    var amp: f32 = _noise_fractal_bounding(octaves, gain);

    for (var i = 0; i < octaves; i++) {
        var noise: f32 = noise_simplex_1d(seed + i, p);
        sum += noise * amp;
        amp *= mix(1.0, min(noise + 1.0, 2.0) * 0.5, weighted_strength);
        p *= lacunarity;
        amp *= gain;
    }

    return sum;
}

