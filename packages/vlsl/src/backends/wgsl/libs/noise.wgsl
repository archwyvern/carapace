            value += (a8 * a8) * (a8 * a8) * _fnlGradCoord3D(seed2,
                                                             i + PRIME_X, j + (yNMask & (i32(u32(PRIME_Y) << 1u))), k + PRIME_Z, x8, y8, z8);
