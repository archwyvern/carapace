                _fnlCubicLerp(_fnlValCoord4D(seed,x0,y1,z1,w0), _fnlValCoord4D(seed,x1,y1,z1,w0), _fnlValCoord4D(seed,x2,y1,z1,w0), _fnlValCoord4D(seed,x3,y1,z1,w0), xs),
