{
  "name": "@carapace/resources",
  "version": "0.0.1",
  "description": "Hardcoded engine resource type hierarchy (Godot-derived) as a standalone TypeScript model. Serialization (vascal) is deferred.",
  "type": "module",
  "license": "MIT",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@carapace/primitives": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.15.17",
    "tsup": "8.3.5",
    "typescript": "5.9.3",
    "vitest": "3.0.0"
  }
}
