{
  "name": "@carapace/shell",
  "version": "0.1.0",
  "description": "Batteries-included React editor-shell: theme, primitives, workbench shell, and a platform host seam.",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist",
    "src/theme.css",
    "src/base.css",
    "src/tree/fileIcons/seti.css",
    "src/tree/fileIcons/seti.woff"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ipc": {
      "types": "./dist/fs/client.d.ts",
      "import": "./dist/fs/client.js"
    },
    "./node": {
      "types": "./dist/fs/node.d.ts",
      "import": "./dist/fs/node.js"
    },
    "./history": {
      "types": "./dist/history/index.d.ts",
      "import": "./dist/history/index.js"
    },
    "./theme.css": "./src/theme.css",
    "./base.css": "./src/base.css",
    "./seti.css": "./src/tree/fileIcons/seti.css"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@fluentui/react-icons": "^2.0.330",
    "@monaco-editor/react": "^4.7.0",
    "chokidar": "5.0.0",
    "clsx": "^2.1.1",
    "prettier": "^3.8.4",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2"
  },
  "peerDependencies": {
    "monaco-editor": ">=0.50",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "22.15.17",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vscode/codicons": "0.0.36",
    "jsdom": "25.0.1",
    "monaco-editor": "0.55.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "8.3.5",
    "typescript": "5.9.3",
    "vitest": "3.0.0"
  }
}
